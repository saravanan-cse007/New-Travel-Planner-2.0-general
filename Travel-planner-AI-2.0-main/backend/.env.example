# ── Database ──────────────────────────────────────────────────────
MONGO_URL=
DB_NAME=travel_planner

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALG=HS256

# ── LLM provider (set at least ONE) ──────────────────────────────
# The backend tries Gemini -> OpenAI -> Anthropic, in that order,
# using whichever of these keys are present. Set just one for a single
# provider, or more than one for automatic fallover between them.
# No Emergent / third-party proxy account is required for any of these
# — they are the vendors' own public APIs.

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_BASE_URL lets you point this at any OpenAI-compatible endpoint
# instead (Azure OpenAI, Groq, Together AI, a local vLLM server, etc.)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Other integrations (all optional; features degrade gracefully) ─
GOOGLE_MAPS_KEY=
OPENWEATHER_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=*
